	<body>
		<a href="index.html">인덱스 페이지</a>
        
        <h1>HTML 리스트</h1>
        
        <h2>순서가 없는 리스트(unordered list)</h2>
        <ul style="list-style: none;">
            <!-- ul 태그의 style 속성 중에서 list-style의 기본값은 disc. 
             list-style 특성 값을 none을 설정하면 bullet 이미지가 사라짐.-->
        
        
        
            <!-- 리스트 아이템(list item) -->
            <li>1승</li>
            <li>모아나2</li>
            <li>소방관</li>
            <li>위키드</li>
        </ul>
	</body>
